# Environment Variables for Zitate Web App
# Copy this file to .env.local and adjust values as needed

# Application Configuration
VITE_APP_NAME=Zitate
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Collect and organize quotes with rich metadata

# Feature Flags
VITE_ENABLE_EXPORT_IMPORT=true
VITE_ENABLE_PWA=true
VITE_ENABLE_MAPS=true
VITE_ENABLE_GEOLOCATION=true

# Map Configuration
VITE_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
VITE_OSM_TILE_URL=https://tile.openstreetmap.org

# Development Settings
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info

# Performance Settings
VITE_VIRTUAL_SCROLL_THRESHOLD=100
VITE_IMAGE_MAX_SIZE_MB=2
VITE_AUDIO_MAX_DURATION_SEC=300

# PWA Settings
VITE_PWA_THEME_COLOR=#3b82f6
VITE_PWA_BACKGROUND_COLOR=#ffffff

# IndexedDB Configuration
VITE_DB_NAME=zitate-db
VITE_DB_VERSION=1

# Build Configuration
VITE_BUILD_TARGET=es2020
VITE_BUILD_MINIFY=terser
VITE_BUILD_SOURCEMAP=false
